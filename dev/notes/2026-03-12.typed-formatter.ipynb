      ],
      "source": [
        "from splatlog.lib.fmt import FmtFunc, FmtWriter\n",
        "\n",
        "\n",
        "@FmtFunc\n",
        "def fmt_obj(f: FmtWriter, value: object) -> None:\n",
        "    f.write_obj(value)\n",
        "\n",
        "\n",
        "fmt_obj.with_opts(fallback=lambda x: f\"hey: {x!r}\")({\"x\": 123})"
      ]
    }
  ],
